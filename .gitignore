# ===========================================
# Shree Label ERP — .gitignore
# ===========================================

# ----- OS files -----
Thumbs.db
Desktop.ini
.DS_Store
._*

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ----- PHP / Composer -----
/vendor/
composer.lock

# ----- Environment / Secrets -----
.env
.env.*
config/db.local.php

# ----- Logs & temp -----
*.log
/logs/
/tmp/
/temp/
/cache/

# ----- Uploads (user-generated content) -----
/uploads/
/storage/

# ----- Node (if ever added) -----
node_modules/
package-lock.json

# ----- Build artifacts -----
*.bak
*.orig
*.old
